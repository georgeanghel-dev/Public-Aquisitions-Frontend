<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Referat de necesitate</title>
  <style>
    * { box-sizing: border-box; }

    html, body {
      font-family: 'Arial', sans-serif;
      font-size: 11px;
      width: 595px !important;
      max-width: 595px !important;
      margin: 0;
      padding: 0;
      word-wrap: break-word;
      color: #1a1a2e;
    }

    /* ── HEADER ─────────────────────────────────────── */
    .page-header, .page-header-space { height: 110px; }
    .page-footer, .page-footer-space { height: 55px; }

    .page-header {
      position: fixed;
      top: 0;
      width: 100%;
      z-index: 9999;
    }

    .page-footer {
      position: fixed;
      bottom: 0;
      width: 100%;
      z-index: 9999;
    }

    .header-band {
      background: linear-gradient(135deg, #1565C0 0%, #1976D2 60%, #1a237e 100%);
      padding: 8px 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 90px;
      position: relative;
    }

    /* Logo stânga */
    .header-logo {
      width: 72px;
      min-width: 72px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .header-logo img {
      width: 68px;
      height: 68px;
      object-fit: contain;
    }

    /* Date instituție centru */
    .header-institution {
      flex: 1;
      text-align: center;
      color: white;
      padding: 0 10px;
    }

    .header-institution .inst-name {
      font-size: 13px;
      font-weight: bold;
      margin-bottom: 3px;
      line-height: 1.3;
    }

    .header-institution .inst-details {
      font-size: 9.5px;
      opacity: 0.9;
      line-height: 1.5;
    }

    .header-institution .inst-details span {
      display: inline-block;
      margin: 0 4px;
    }

    /* Spațiu sigiliu electronic dreapta */
    .header-seal {
      width: 120px;
      min-width: 120px;
      height: 84px;
      border: 1.5px dashed rgba(255,255,255,0.55);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.65);
      font-size: 8px;
      text-align: center;
      padding: 6px;
      line-height: 1.4;
    }

    /* Bandă albastru deschis sub header */
    .header-accent {
      background: #E3F2FD;
      border-top: 2px solid #1565C0;
      padding: 3px 14px;
      font-size: 9px;
      color: #1565C0;
      font-weight: 600;
      letter-spacing: 0.04em;
    }

    /* ── FOOTER ─────────────────────────────────────── */
    .footer-band {
      background: #f5f7fa;
      border-top: 1.5px solid #1565C0;
      padding: 6px 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-text {
      font-size: 8.5px;
      color: #555;
    }

    .footer-logo-text {
      font-size: 10px;
      font-weight: bold;
      color: #1565C0;
      letter-spacing: 0.02em;
    }

    .footer-logo-text span {
      color: #e53935;
    }

    /* ── CONȚINUT ────────────────────────────────────── */
    .content {
      padding: 8px 14px 4px;
    }

    /* Titlu secțiune */
    .section-title {
      display: inline-block;
      background: #1565C0;
      color: white;
      font-size: 10px;
      font-weight: bold;
      padding: 3px 10px;
      border-radius: 20px;
      margin: 6px 0 5px;
      letter-spacing: 0.03em;
    }

    /* Card informații */
    .info-card {
      border: 1px solid #e0e8f8;
      border-radius: 6px;
      padding: 7px 10px;
      background: #fafcff;
      margin-bottom: 6px;
    }

    .info-grid {
      display: table;
      width: 100%;
    }

    .info-row {
      display: table-row;
    }

    .info-label {
      display: table-cell;
      font-style: italic;
      color: #555;
      width: 45%;
      padding: 1.5px 0;
      vertical-align: top;
    }

    .info-value {
      display: table-cell;
      font-weight: 500;
      color: #1a1a2e;
      padding: 1.5px 0 1.5px 5px;
      vertical-align: top;
    }

    /* Tabel produse */
    .products-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 6px;
      table-layout: fixed;
    }

    .products-table th {
      background: #1565C0;
      color: white;
      padding: 4px 4px;
      font-size: 8px;
      text-align: left;
      font-weight: 600;
      word-wrap: break-word;
    }

    .products-table td {
      padding: 3.5px 4px;
      font-size: 9px;
      border-bottom: 1px solid #e8eef8;
      vertical-align: top;
      word-wrap: break-word;
    }

    .products-table tr:nth-child(even) td {
      background: #f0f5ff;
    }

    .products-table .num-cell {
      text-align: right;
    }

    .products-table .desc-cell {
      font-size: 8.5px;
      color: #333;
      line-height: 1.4;
    }

    .products-table .total-row td {
      background: #e3f2fd !important;
      font-weight: bold;
      border-top: 1.5px solid #1565C0;
    }

    /* Coloane fixe tabel produse */
    .col-name { width: 16%; }
    .col-req  { width: 12%; }
    .col-date { width: 9%; }
    .col-cpv  { width: 9%; }
    .col-mu   { width: 4%; }
    .col-qty  { width: 5%; }
    .col-puf  { width: 8%; }
    .col-puc  { width: 8%; }
    .col-ptf  { width: 8%; }
    .col-ptc  { width: 8%; }
    .col-desc { width: 13%; }

    /* Rând 2 coloane pentru destinație + tip contract */
    .two-col {
      display: table;
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 6px;
    }

    .two-col-left, .two-col-right {
      display: table-cell;
      width: 50%;
      vertical-align: top;
    }

    .two-col-left {
      padding-right: 5px;
    }

    .two-col-right {
      padding-left: 5px;
      border-left: 1px solid #e0e8f8;
    }

    /* Checkbox items */
    .check-list {
      list-style: none;
      padding: 0;
      margin: 3px 0;
    }

    .check-list li {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 1.5px 0;
      font-size: 10px;
    }

    .check-icon {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      font-weight: bold;
      flex-shrink: 0;
    }

    .check-icon.checked {
      background: #1565C0;
      color: white;
    }

    .check-icon.unchecked {
      background: #f0f0f0;
      color: #999;
      border: 1px solid #ddd;
    }

    /* Rând PAAP + Clasificatie bugetara */
    .paap-budget-row {
      display: table;
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 6px;
    }

    .paap-col, .budget-col {
      display: table-cell;
      width: 50%;
      vertical-align: top;
    }

    .paap-col {
      padding-right: 5px;
    }

    .budget-col {
      padding-left: 5px;
      border-left: 1px solid #e0e8f8;
    }

    /* Sub-titlu mic */
    .sub-title {
      font-size: 9.5px;
      font-weight: bold;
      color: #1565C0;
      margin: 4px 0 2px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .sub-value {
      font-size: 10px;
      color: #1a1a2e;
      padding: 2px 0;
    }

    /* Clasificatie bugetara badge */
    .budget-badge {
      display: inline-block;
      background: #e8f5e9;
      color: #2e7d32;
      border-radius: 4px;
      padding: 2px 7px;
      font-size: 9.5px;
      font-weight: 600;
      margin: 1px 0;
    }

    /* Secțiuni text */
    .text-section {
      margin-bottom: 5px;
    }

    .text-section .text-label {
      font-size: 9.5px;
      font-weight: bold;
      color: #444;
      margin-bottom: 1px;
    }

    .text-section .text-value {
      font-size: 10px;
      color: #1a1a2e;
      padding: 3px 7px;
      background: #fafcff;
      border-left: 2px solid #1565C0;
      border-radius: 0 3px 3px 0;
    }

    /* Obiective lista */
    .obj-list {
      margin: 2px 0 2px 10px;
      padding: 0;
    }

    .obj-list li {
      font-size: 10px;
      padding: 1px 0;
      color: #1a1a2e;
    }

    /* Calendar */
    .calendar-box {
      background: #f0f5ff;
      border: 1px solid #c5d5f5;
      border-radius: 5px;
      padding: 5px 8px;
      font-size: 10px;
    }

    .calendar-date {
      font-weight: 600;
      color: #1565C0;
    }

    /* Divider */
    .divider {
      border: none;
      border-top: 1px solid #e0e8f8;
      margin: 5px 0;
    }

    /* Clasificatie functionala accent */
    .func-accent {
      border-left: 3px solid #1565C0;
      padding-left: 5px;
      margin: 2px 0;
      font-size: 10px;
      color: #1565C0;
      font-style: italic;
    }

    @page { margin: 8mm 6mm; }

    @media print {
      thead { display: table-header-group; }
      tfoot { display: table-footer-group; }
      body { margin: 0; }
    }

    /* ── SEMNĂTURI ───────────────────────────────────────── */
    .signatures-section {
      margin-top: 10px;
      page-break-inside: avoid;
    }

    .signatures-grid {
      display: table;
      width: 100%;
      border-collapse: collapse;
    }

    .signatures-row {
      display: table-row;
    }

    .signature-cell {
      display: table-cell;
      width: 50%;
      padding: 4px 6px;
      vertical-align: top;
    }

    .signature-box {
      border: 1px solid #c5d5f5;
      border-radius: 5px;
      padding: 6px 8px;
      background: #fafcff;
      min-height: 65px;
    }

    .sig-role {
      font-size: 8.5px;
      font-weight: bold;
      color: #1565C0;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      margin-bottom: 2px;
    }

    .sig-name {
      font-size: 9.5px;
      color: #1a1a2e;
      font-weight: 500;
      margin-bottom: 2px;
    }

    .sig-date {
      font-size: 8.5px;
      color: #555;
      margin-bottom: 2px;
    }

    .sig-line {
      border-top: 1px solid #1565C0;
      margin-top: 20px;
      padding-top: 3px;
      font-size: 8px;
      color: #888;
      text-align: center;
    }

    .sig-status-badge {
      display: inline-block;
      padding: 1px 6px;
      border-radius: 10px;
      font-size: 8px;
      font-weight: 600;
    }

    .sig-status-badge.signed {
      background: #E8F5E9;
      color: #2E7D32;
    }

    .sig-status-badge.pending {
      background: #FFF8E1;
      color: #F57F17;
    }

    .sig-status-badge.rejected {
      background: #FFEBEE;
      color: #C62828;
    }
  </style>
</head>
<body>

  <!-- ══ HEADER FIXED ══════════════════════════════════════════ -->
  <div class="page-header">
    <div class="header-band">
      <!-- Logo instituție stânga -->
      <div class="header-logo">
        {{{institutionLogo}}}
      </div>

      <!-- Date instituție centru -->
      <div class="header-institution">
        {{#ifAll institution}}
        <div class="inst-name">{{institution.name}}</div>
        <div class="inst-details">
          <span><b>Adresa:</b> {{institution.address}}</span><br/>
          <span><b>Tel:</b> {{institution.phone}}</span>
          <span style="margin-left:8px"><b>Email:</b> {{institution.email}}</span>
        </div>
        {{/ifAll}}
      </div>

      <!-- Spațiu sigiliu electronic dreapta -->
      <div class="header-seal">
        Sigilat digital de:<br/>
        {{#ifAll institution}}{{institution.name}}{{/ifAll}}
      </div>
    </div>
    <div class="header-accent">REFERAT DE NECESITATE</div>
  </div>

  <!-- ══ FOOTER FIXED ══════════════════════════════════════════ -->
  <div class="page-footer">
    <div class="footer-band">
      <div class="footer-text">Referatul de necesitate a fost generat în platforma ConectX.</div>
      <div class="footer-logo-text">conect<span>x</span> &nbsp;·&nbsp; www.conectx.net</div>
    </div>
  </div>

  <!-- ══ TABEL STRUCTURA PAGE ══════════════════════════════════ -->
  <table>
    <thead><tr><td><div class="page-header-space"></div></td></tr></thead>
    <tbody>
      <tr>
        <td>
          <div class="content">

            <!-- ── INFORMAȚII REFERAT ── -->
            <div class="section-title">Informații Referat</div>
            <div class="info-card">
              <div class="info-grid">
                <div class="info-row">
                  <div class="info-label">Denumirea referat:</div>
                  <div class="info-value">{{name}}</div>
                </div>
                <div class="info-row">
                  <div class="info-label">Instituția:</div>
                  <div class="info-value">{{#ifAll institution}}{{institution.name}}{{/ifAll}}</div>
                </div>
                <div class="info-row">
                  <div class="info-label">Departamentul:</div>
                  <div class="info-value">{{department.name}}</div>
                </div>
                <div class="info-row">
                  <div class="info-label">Utilizatorul:</div>
                  <div class="info-value">{{referenceInfo.user}}</div>
                </div>
                <div class="info-row">
                  <div class="info-label">Data creării:</div>
                  <div class="info-value">{{referenceInfo.date}}</div>
                </div>
              </div>
            </div>

            <!-- ── DESCRIEREA PRODUSELOR ── -->
            <div class="section-title">Descrierea produselor</div>
            <table class="products-table">
              <thead>
                <tr>
                  <th class="col-name">Denumire propunere</th>
                  <th class="col-req">Solicitant / Id ConectX</th>
                  <th class="col-date">Data creării</th>
                  <th class="col-cpv">Cod CPV</th>
                  <th class="col-mu">U.M.</th>
                  <th class="col-qty num-cell">Cant.</th>
                  <th class="col-puf num-cell">Val. unit. f.TVA</th>
                  <th class="col-puc num-cell">Val. unit. c.TVA</th>
                  <th class="col-ptf num-cell">Total f.TVA</th>
                  <th class="col-ptc num-cell">Total c.TVA</th>
                  <th class="col-desc">Descriere tehnică</th>
                </tr>
              </thead>
              <tbody>
                {{#each achizitionDesc.table.data}}
                <tr>
                  <td class="col-name">{{this.[0]}}</td>
                  <td class="col-req">{{this.[1]}}</td>
                  <td class="col-date">{{this.[2]}}</td>
                  <td class="col-cpv">{{this.[3]}}</td>
                  <td class="col-mu">{{this.[4]}}</td>
                  <td class="col-qty num-cell">{{this.[5]}}</td>
                  <td class="col-puf num-cell">{{this.[6]}}</td>
                  <td class="col-puc num-cell">{{this.[7]}}</td>
                  <td class="col-ptf num-cell">{{this.[8]}}</td>
                  <td class="col-ptc num-cell">{{this.[9]}}</td>
                  <td class="col-desc desc-cell">{{{this.[10]}}}</td>
                </tr>
                {{/each}}
                <tr class="total-row">
                  <td colspan="8" style="text-align:right">Total:</td>
                  <td class="num-cell">{{totalWoTva}}</td>
                  <td class="num-cell">{{totalWithTva}}</td>
                  <td></td>
                </tr>
              </tbody>
            </table>

            <!-- ── DESTINAȚIE + TIP CONTRACT + PAAP + CLASIFICATIE (un rând) ── -->
            <!-- Rândul 1: Destinație achiziție | Tipul contractului -->
            <div class="two-col" style="margin-bottom:4px">
              <div class="two-col-left">
                <div class="sub-title">Destinaţia achiziţiei</div>
                <ul class="check-list">
                  {{#each achizitionDesc.destination}}
                  <li>
                    <span class="check-icon {{#if this.checked}}checked{{else}}unchecked{{/if}}">
                      {{#if this.checked}}✓{{else}}✕{{/if}}
                    </span>
                    {{this.label}}
                  </li>
                  {{/each}}
                </ul>
              </div>
              <div class="two-col-right">
                <div class="sub-title">Tipul contractului</div>
                <!-- Tipul contractului pe un singur rând -->
                <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:3px">
                  {{#each achizitionDesc.type}}
                  <span style="display:inline-flex; align-items:center; gap:3px; font-size:10px">
                    <span class="check-icon {{#if this.checked}}checked{{else}}unchecked{{/if}}" style="width:12px;height:12px;font-size:8px">
                      {{#if this.checked}}✓{{else}}✕{{/if}}
                    </span>
                    {{this.label}}
                  </span>
                  {{/each}}
                </div>
              </div>
            </div>

            <!-- Rândul 2: Modalitate centralizare PAAP | Clasificatie bugetară -->
            <div class="paap-budget-row">
              <div class="paap-col">
                <div class="sub-title">Modalitatea de centralizare în PAAP</div>
                <div class="sub-value">
                  {{#if modalitateDeCentralizare}}
                    {{modalitateDeCentralizare.label}} - {{modalitateDeCentralizare.key}} - {{modalitateDeCentralizare.cpvName}}
                  {{else}}
                    —
                  {{/if}}
                </div>
              </div>
              <div class="budget-col">
                <div class="sub-title">Clasificație bugetară</div>
                {{#if budgetClassification}}
                  {{#each budgetClassification}}
                  <div>
                    <div style="font-size:9px; color:#555; margin-top:2px">
                      {{#if (eq this.type 'economic')}}Economică{{else}}Funcțională{{/if}}
                    </div>
                    <div class="budget-badge">{{this.titlu}} - {{this.name}}</div>
                  </div>
                  {{/each}}
                {{else}}
                  <div class="func-accent">—</div>
                {{/if}}
              </div>
            </div>

            <hr class="divider"/>

            <!-- ── FUNDAMENTARE ── -->
            {{#if fundamentNeed}}
            <div class="section-title">Fundamentare</div>
            <div class="text-section">
              <div class="text-value">{{{fundamentNeed}}}</div>
            </div>
            {{/if}}

            <!-- ── CONTRIBUȚIA LA OBIECTIVE ── -->
            <div class="section-title">Contribuția achiziției la îndeplinirea obiectivelor</div>
            <div class="info-card">
              {{#if identifiedNeed}}
              <div class="text-section">
                <div class="text-label">Necesitatea identificată</div>
                <div class="text-value">{{{identifiedNeed}}}</div>
              </div>
              {{/if}}

              {{#if obectives1.ob1.length}}
              <div class="text-section">
                <div class="text-label">Obiectivele autorităţii contractante</div>
                <ol class="obj-list">
                  {{#each obectives1.ob1}}
                  <li>{{this.label}}</li>
                  {{/each}}
                </ol>
              </div>
              {{/if}}

              {{!-- ob2 (Obiectivele proiectului) și ob3 (Obiectivele din strategie) ELIMINATE --}}

              {{#if obectives1.ob4.length}}
              <div class="text-section">
                <div class="text-label">Beneficiile obținute</div>
                <ol class="obj-list">
                  {{#each obectives1.ob4}}
                  <li>{{this}}</li>
                  {{/each}}
                </ol>
              </div>
              {{/if}}
            </div>

            <!-- ── JUSTIFICAREA MODALITĂȚII ── -->
            {{#if justificationChoice}}
            <div class="section-title">Justificarea modalităţii</div>
            <div class="text-section">
              <div class="text-value">{{{justificationChoice}}}</div>
            </div>
            {{/if}}

            <!-- ── NEVOIA ÎN CONTEXTUL LEGISLAȚIEI ── -->
            {{#if legislationContext.cpvCodes.length}}
            <div class="section-title">Nevoia în contextul legislației</div>
            <div class="info-card">
              <div class="sub-title" style="margin-bottom:4px">Cod CPV pentru descrierea obiectului contractului</div>
              <table class="products-table" style="margin:0">
                <thead>
                  <tr>
                    <th>Cod CPV principal</th>
                    <th>Categorie achiziție</th>
                    <th>Cantitate</th>
                    <th>Unitate de măsură</th>
                  </tr>
                </thead>
                <tbody>
                  {{#each legislationContext.cpvCodes}}
                  <tr>
                    <td>{{this.cpvCode}}</td>
                    <td>{{this._label}}</td>
                    <td>{{this.qty}}</td>
                    <td>{{this.mu}}</td>
                  </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
            {{/if}}

            <!-- ── STADIUL REZULTATELOR ── -->
            {{#if docSuports.desc}}
            <div class="section-title">Stadiul rezultatelor</div>
            <div class="info-card">
              <div class="sub-title">Descriere produse</div>
              {{#each priceUnits}}
              <div style="margin-bottom:4px; font-size:10px">
                <b>{{@index_plus_1}}. Nume nevoie: {{this.[0]}}</b><br/>
                <span style="color:#555">{{{this.[6]}}}</span>
              </div>
              {{/each}}
              {{#if docSuports.requirements.length}}
              <div class="sub-title" style="margin-top:5px">Descrierea rezultatului urmărit la finalul contractului</div>
              <ol class="obj-list">
                {{#each docSuports.requirements}}
                <li>{{this}}</li>
                {{/each}}
              </ol>
              {{/if}}
            </div>
            {{/if}}

            <!-- ── CALENDARUL ACHIZIȚIILOR ── -->
            {{#if calendar.signContract}}
            <div class="section-title">Calendarul achizițiilor</div>
            <div class="calendar-box">
              {{#if calendar.signContract}}
              <div><span style="color:#555">Data estimată a achiziției:</span>
                <span class="calendar-date"> {{calendar.signContract}}</span>
              </div>
              {{/if}}
              {{#if calendar.finishContract}}
              <div style="margin-top:2px"><span style="color:#555">Finalizarea contractului:</span>
                <span class="calendar-date"> {{calendar.finishContract}}</span>
              </div>
              {{/if}}
              {{#if calendar.fulfillmentOfObligations}}
              <div style="margin-top:2px"><span style="color:#555">Evaluarea obligațiilor:</span>
                <span class="calendar-date"> {{calendar.fulfillmentOfObligations}}</span>
              </div>
              {{/if}}
              {{#if calendar.release}}
              <div style="margin-top:2px"><span style="color:#555">Evaluarea finală:</span>
                <span class="calendar-date"> {{calendar.release}}</span>
              </div>
              {{/if}}
            </div>
            {{/if}}

          </div><!-- /content — signatures below -->

          <!-- ══ SEMNĂTURI ═══════════════════════════════════════════ -->
          {{#if signatories.length}}
          <div class="content signatures-section">
            <div class="section-title">Semnături</div>
            <div class="signatures-grid">
              {{#each signatories}}
              {{#if (isEven @index)}}
              <div class="signatures-row">
              {{/if}}
                <div class="signature-cell">
                  <div class="signature-box">
                    <div class="sig-role">{{this.role}}</div>
                    <div class="sig-name">{{this.name}}</div>
                    {{#if this.date}}
                    <div class="sig-date">Data: {{this.date}}</div>
                    {{/if}}
                    <div class="sig-line">
                      {{#if (eq this.status 'signed')}}
                      <span class="sig-status-badge signed">✓ Semnat electronic</span>
                      {{else if (eq this.status 'rejected')}}
                      <span class="sig-status-badge rejected">✕ Respins</span>
                      {{else}}
                      <span class="sig-status-badge pending">⏳ În așteptare</span>
                      {{/if}}
                    </div>
                  </div>
                </div>
              {{#if (isOdd @index)}}
              </div>
              {{/if}}
              {{/each}}
              {{#if (isOdd signatories.length)}}
              <div class="signature-cell"></div>
              </div>
              {{/if}}
            </div>
          </div>
          {{/if}}
        </td>
      </tr>
    </tbody>
    <tfoot><tr><td><div class="page-footer-space"></div></td></tr></tfoot>
  </table>

</body>
</html>
